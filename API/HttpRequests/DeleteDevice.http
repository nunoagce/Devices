# @name createDevice
POST {{API_HostAddress}}/devices/
Accept: application/json
Content-Type: application/json

{
  "name": "N-{{$randomInt}}",
  "brand": "B-{{$randomInt}}",
  "state": "Available"
}
###

@newDeviceId = {{createDevice.response.headers.Location}}

### Delete the device
DELETE {{newDeviceId}}

###


GET {{newDeviceId}}
Accept: application/json